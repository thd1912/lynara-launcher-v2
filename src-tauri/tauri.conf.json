{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lynara Launcher",
  "version": "1.0.1",
  "identifier": "fr.lynara.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lynara Launcher",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Lynara",
    "homepage": "https://lynara.fr",
    "category": "Game",
    "shortDescription": "Launcher officiel du serveur Lynara",
    "longDescription": "Launcher officiel du serveur Minecraft Lynara - Mounts of Mayhem. Connexion Microsoft, installation automatique des mods et shaders, et lancement direct vers play.lynara.fr.",
    "copyright": "© 2026 Lynara",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["fr-FR", "en-US"]
      },
      "nsis": {
        "languages": ["French", "English"],
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/thd1912/lynara-launcher-v2/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBRTU0MEJERTQyMzkxMzIKUldReWtTUGt2VURsZWpEazNGSElyVVF6OFZkVmV1WWhhSEJIdGFNbVkra1NmZmo0NEFSSFI0RWEK"
    }
  }
}
